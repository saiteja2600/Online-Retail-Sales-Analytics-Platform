{
  "datasets": [
    {
      "name": "8a1ddc27",
      "displayName": "Top Monthly Sales And Shipping Revenue Summary",
      "queryLines": [
        "SELECT \r\n",
        "    ms.year,\r\n",
        "    ms.month,\r\n",
        "    SUM(ms.total_orders) AS total_orders,\r\n",
        "    ROUND(SUM(ms.shipping),2) AS shipping_revenue,\r\n",
        "    ROUND((SUM(ms.shipping) / SUM(ms.total_sales)) * 100,2) AS shipping_percentage,\r\n",
        "    ROUND(SUM(ms.total_sales),2) AS total_sales\r\n",
        "FROM monthlysales ms\r\n",
        "GROUP BY ms.year, ms.month\r\n",
        "ORDER BY total_orders DESC;"
      ],
      "catalog": "onlineretail",
      "schema": "onlineretail_schema"
    },
    {
      "name": "f23952f1",
      "displayName": "Sales Insights by Product Type",
      "queryLines": [
        "SELECT \r\n",
        "    ps.product_type,\r\n",
        "    ROUND(SUM(ps.net_quantity), 2) AS total_quantity_sold,\r\n",
        "    ROUND(SUM(ps.gross_sales), 2) AS total_gross_sales,\r\n",
        "    concat(ROUND((ABS(SUM(ps.discounts)) / SUM(ps.gross_sales)) * 100,2) ,\"%\")AS discount_percentage,\r\n",
        "concat(ROUND((ABS(SUM(ps.returns)) / SUM(ps.gross_sales)) * 100,2),\"%\") AS return_percentage,\r\n",
        "    ROUND(SUM(ps.total_net_sales), 2) AS total_net_sales\r\n",
        "FROM products_sales ps\r\n",
        "GROUP BY ps.product_type\r\n",
        "ORDER BY total_net_sales DESC\r\n",
        "LIMIT 10;"
      ],
      "catalog": "onlineretail",
      "schema": "onlineretail_schema"
    },
    {
      "name": "44a06fa5",
      "displayName": "Top Ten Product Sales Summary with Discounts and Returns",
      "queryLines": [
        "SELECT \n",
        "    ps.product_type,\n",
        "    ROUND(SUM(ps.net_quantity), 2) AS total_quantity_sold,\n",
        "    ROUND(SUM(ps.gross_sales), 2) AS total_gross_sales,\n",
        "        ROUND((ABS(SUM(ps.discounts)) / SUM(ps.gross_sales)) * 100,2) AS discount,\n",
        "    concat(ROUND((ABS(SUM(ps.discounts)) / SUM(ps.gross_sales)) * 100,2) ,\"%\")AS discount_percentage,\n",
        "ROUND((ABS(SUM(ps.returns)) / SUM(ps.gross_sales)) * 100,2) AS returns,\n",
        "concat(ROUND((ABS(SUM(ps.returns)) / SUM(ps.gross_sales)) * 100,2),\"%\") AS return_percentage,\n",
        "    ROUND(SUM(ps.total_net_sales), 2) AS total_net_sales\n",
        "FROM products_sales ps\n",
        "GROUP BY ps.product_type\n",
        "ORDER BY total_net_sales DESC\n",
        "LIMIT 5;"
      ],
      "catalog": "onlineretail",
      "schema": "onlineretail_schema"
    },
    {
      "name": "3a24232f",
      "displayName": "Top Monthly Sales Performance Summary",
      "queryLines": [
        "SELECT \r\n",
        "    ms.year,\r\n",
        "    ms.month,\r\n",
        "    ROUND(SUM(ms.total_orders), 2) AS total_orders,\r\n",
        "    ROUND(SUM(ms.gross_sales), 2) AS gross_sales,\r\n",
        "        ROUND((ABS(SUM(ms.discounts)) / SUM(ms.gross_sales)) * 100, 2) AS discount,\r\n",
        "\r\n",
        "    CONCAT(ROUND((ABS(SUM(ms.discounts)) / SUM(ms.gross_sales)) * 100, 2), \"%\") AS discount_percentage,\r\n",
        "        ROUND((ABS(SUM(ms.returns)) / SUM(ms.gross_sales)) * 100, 2) AS returns,\r\n",
        "\r\n",
        "    concat(ROUND((ABS(SUM(ms.returns)) / SUM(ms.gross_sales)) * 100, 2),\"%\") AS return_percentage,\r\n",
        "    ROUND(SUM(ms.net_sales), 2) AS net_sales,\r\n",
        "    ROUND(SUM(ms.shipping), 2) AS shipping,\r\n",
        "    ROUND(SUM(ms.total_sales), 2) AS total_sales\r\n",
        "FROM monthlysales ms\r\n",
        "GROUP BY ms.year, ms.month\r\n",
        "ORDER BY total_orders DESC\r\n",
        "LIMIT 10;"
      ],
      "catalog": "onlineretail",
      "schema": "onlineretail_schema"
    },
    {
      "name": "6eb757dd",
      "displayName": "Product Sales Discounts and Returns Summary Report",
      "queryLines": [
        "SELECT \r\n",
        "    ps.product_type,\r\n",
        "    ROUND(SUM(ps.discounts), 2) AS total_discounts,\r\n",
        "    ROUND(SUM(ps.returns), 2) AS total_returns,\r\n",
        "    ROUND((SUM(ps.discounts) / SUM(ps.gross_sales)) * 100, 2) AS discount_percentage,\r\n",
        "    ROUND((SUM(ps.returns) / SUM(ps.gross_sales)) * 100, 2) AS return_percentage\r\n",
        "FROM products_sales ps\r\n",
        "GROUP BY ps.product_type\r\n",
        "ORDER BY total_discounts LIMIT 10;"
      ],
      "catalog": "onlineretail",
      "schema": "onlineretail_schema"
    },
    {
      "name": "fe9cb69a",
      "displayName": "Top Five Product Types by Sales Revenue Share",
      "queryLines": [
        "SELECT \r\n",
        "    ps.product_type,\r\n",
        "    ROUND(SUM(ps.total_net_sales), 2) AS total_sales,\r\n",
        "    ROUND(\r\n",
        "        (SUM(ps.total_net_sales) / SUM(SUM(ps.total_net_sales)) OVER ()) * 100,\r\n",
        "        2\r\n",
        "    ) AS revenue_percentage,\r\n",
        "    concat(\r\n",
        "        ROUND(\r\n",
        "            (SUM(ps.total_net_sales) / SUM(SUM(ps.total_net_sales)) OVER ()) * 100,\r\n",
        "            2\r\n",
        "        ),\r\n",
        "        \"%\"\r\n",
        "    ) AS revenue\r\n",
        "FROM products_sales ps\r\n",
        "GROUP BY ps.product_type\r\n",
        "ORDER BY total_sales DESC\r\n",
        "LIMIT 5;"
      ],
      "catalog": "onlineretail",
      "schema": "onlineretail_schema"
    }
  ],
